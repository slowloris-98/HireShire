      "isDeleted": false,
      "boundElements": [],
      "updated": 1784143361264,
      "link": null,
      "locked": false,
      "text": "-> Scrapper -  Collect jobs from sources\n\n-> Matcher - Filter, Funnel and Score relevant jobs\n\n-> Tuner - Evaluator - Evaluate current resume + JD -> generate critic report\n                - Optimizer - Optimizes the resume based on critic + jd + project file\n\n-> Applier - Apply on all the shortlisted jobs with custom resume, cover letter.\n                ",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> Scrapper -  Collect jobs from sources\n\n-> Matcher - Filter, Funnel and Score relevant jobs\n\n-> Tuner - Evaluator - Evaluate current resume + JD -> generate critic report\n                - Optimizer - Optimizes the resume based on critic + jd + project file\n\n-> Applier - Apply on all the shortlisted jobs with custom resume, cover letter.\n                ",
      "autoResize": true,
      "lineHeight": 1.25
    },
